import pandas as pd
import matplotlib.pyplot as plt

trades = pd.read_csv("historical_data.csv")
sentiment = pd.read_csv("fear_greed_index.csv")

trades.head(), sentiment.head()

trades["date"] = pd.to_datetime(trades["Timestamp IST"]).dt.date
sentiment["date"] = pd.to_datetime(sentiment["timestamp"]).dt.date

df = trades.merge(sentiment, on="date", how="left")
df.head()

pnl_sentiment = df.groupby("classification")["Closed PnL"].mean()
pnl_sentiment



plt.figure()
pnl_sentiment.plot(kind="bar")
plt.title("Average PnL by Market Sentiment")
plt.xlabel("Sentiment")
plt.ylabel("Average PnL")
plt.show()






trade_counts = trades["Account"].value_counts()
trade_counts.describe()
plt.figure()
trade_counts.plot(kind="hist", bins=30)
plt.title("Distribution of Trades per Trader")
plt.xlabel("Number of Trades")
plt.ylabel("Frequency")
plt.show()







side_ratio = trades["Side"].value_counts(normalize=True)
side_ratio


plt.figure()
side_ratio.plot(kind="bar")
plt.title("Long vs Short Trade Ratio")
plt.xlabel("Trade Type")
plt.ylabel("Proportion")
plt.show()
